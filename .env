THEME=https://raw.githubusercontent.com/chad-bennett/al-dente-obsidian-theme/HEAD/theme.css
BASE_THEME=light
dgHomeLink=true
dgShowBacklinks=true
dgShowLocalGraph=true
dgShowInlineTitle=true
dgShowFileTree=true
dgEnableSearch=true
dgShowToc=true
dgLinkPreview=false
dgShowTags=true
SITE_NAME_HEADER=Estadística
SITE_MAIN_LANGUAGE=en
SITE_BASE_URL=https://estadisticaespacial.vercel.app/
SHOW_CREATED_TIMESTAMP=false
TIMESTAMP_FORMAT=MMM dd, yyyy h:mm a
SHOW_UPDATED_TIMESTAMP=false
NOTE_ICON_DEFAULT=
NOTE_ICON_TITLE=false
NOTE_ICON_FILETREE=true
NOTE_ICON_INTERNAL_LINKS=true
NOTE_ICON_BACK_LINKS=true
STYLE_SETTINGS_CSS=body.css-settings-manager { --lc-bg-left: 30px; --lc-bg-top-reading: 31px; --setting-hr-icon: 'EE'; --setting-h1-size: 1.7; --setting-h1-weight: 700; } body.theme-light.css-settings-manager { --setting-line-active-color: 0,0%,97.6470588235294%,1; } body.theme-dark.css-settings-manager { }
STYLE_SETTINGS_BODY_CLASSES=mod-windows is-frameless is-hidden-frameless obsidian-app styled-scrollbars is-floating-nav auto-full-screen show-ribbon show-view-header theme-light css-settings-manager anp-td-none iconic-clickable-icons iconic-markdown-tab-icons show-inline-title is-maximized color-use-custom color-active-default-light color-active-default-dark app-layout-card app-layout-card-border app-layout-card-gradient enable-blur explorer-icon search-internal-enable modal-setting-header modal-setting-header-title-center modal-setting-header-search enable-group-title modal-will-change modal-control-gradient modal-slider modal-toggle-default tab-float tab-show-close-default tab-title-bar-text-default status-bar-style-float status-bar-default message-modify scrollbar-enable scrollbar-hover-accent editor-bg-plain editor-custom-bottom-spacing line-indicator-full line-active-enable text-highlight-all-round font-maple link-icon heading-color-colorful heading-indicator-auto heading-h1-block heading-h1-full-line-both heading-h1-block-contrast heading-h1-center heading-h2-full-line heading-h2-full-line-both heading-h2-center heading-h3-normal heading-h3-full-line-both heading-h4-normal heading-h4-full-line-both heading-h5-normal heading-h5-full-line-both heading-h6-normal heading-h6-full-line-both heading-h6-caps table-full table-style-default table-round embed-title-right-top image-alt image-dark-hover quote-shadow list-enable list-bullet-thread-style list-checkbox-decoration-default list-checkbox-alternative code-line-number code-language code-nowrap code-theme tag-outline pdf-dark-hover calendar-end-disable mobile-floating-button is-focused
